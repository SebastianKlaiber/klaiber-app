---
// Footer component with links to important pages
---

<footer>
  <div class="footer-container">
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/privacy">Privacy Policy</a>
    </div>
    <div class="footer-copyright">
      &copy; {new Date().getFullYear()} All Rights Reserved
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 1.5rem 0;
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: #4b5563;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #000;
    text-decoration: underline;
  }

  .footer-copyright {
    color: #6b7280;
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .footer-container {
      gap: 0.75rem;
    }
  }
</style> 